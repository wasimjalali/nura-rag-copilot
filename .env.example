# Convex local connection.
# `npx convex dev` usually writes these into `.env.local` for you.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Microsoft Foundry / Azure OpenAI server-side values.
# Prefer storing these in Convex env with `npx convex env set NAME`.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_CHAT_DEPLOYMENT=

# Optional fallback for direct OpenAI access
OPENAI_API_KEY=
